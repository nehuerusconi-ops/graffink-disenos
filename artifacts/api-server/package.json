    "@types/pdfkit": "^0.17.6",
    "@types/supertest": "^7.2.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "supertest": "^7.2.2",
    "thread-stream": "3.1.0",
    "vitest": "^4.1.5"
